{
  // https://aka.ms/tsconfig
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "include": [
    "./src/htmlminifier.js"
  ],
  "compilerOptions": {
    // File layout
    "rootDir": "./src",
    "outDir": "./dist/types",

    // Node type definitions for `process`, `Buffer`, etc.
    "types": ["node"],

    // JavaScript support
    "checkJs": true,

    // Outputs
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true
  }
}