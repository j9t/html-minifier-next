{
  // https://aka.ms/tsconfig
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "include": [
    "./tests/**/*.ts"
  ],
  "compilerOptions": {
    // No Node types—tests don’t use `process`/`Buffer` directly
    "types": [],

    // Don’t emit files, just check types
    "noEmit": true
  }
}